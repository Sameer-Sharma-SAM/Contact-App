<%- include('partials/header.ejs') %>

<main class="ca-error-page">
  <div style="animation: fadeUp 0.45s cubic-bezier(0.22,1,0.36,1) both;">

    <!-- BIG 404 -->
    <div class="ca-error-code">404</div>

    <!-- DIVIDER LINE -->
    <div style="
      width: 60px;
      height: 2px;
      background: var(--olive);
      margin: 0 auto 1.25rem;
      border-radius: 2px;
    "></div>

    <!-- MESSAGE -->
    <% if(message){ %>
      <p class="ca-error-msg"><%= message %></p>
    <% } else { %>
      <p class="ca-error-msg">Oops — this page doesn't exist.</p>
    <% } %>

    <!-- SUBTEXT -->
    <p style="
      font-family: 'DM Sans', sans-serif;
      font-size: 0.85rem;
      color: var(--text-soft);
      margin-bottom: 2rem;
    ">
      The page you're looking for may have been moved or deleted.
    </p>

    <!-- BACK BUTTON -->
    <a href="/" class="ca-btn-primary" style="display:inline-flex;">
      <i class="fa fa-arrow-left"></i> Back to Contacts
    </a>

  </div>
</main>

<%- include('partials/footer.ejs') %>