<%- include('partials/header.ejs') %>

<main class="ca-page">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-12 col-md-8 col-lg-7">

        <!-- PAGE HEADER -->
        <div class="mb-4" style="animation: fadeUp 0.35s cubic-bezier(0.22,1,0.36,1) both;">
          <div class="ca-badge">👁 Viewing</div>
          <h1 style="font-family:'Playfair Display',serif; font-size:clamp(1.8rem,4vw,2.4rem); font-weight:900; color:var(--text-light); letter-spacing:-0.02em; margin:0 0 0.25rem;">
            Contact Details
          </h1>
          <p style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:var(--text-soft); margin:0;">
            Viewing full details for this contact
          </p>
        </div>

        <!-- CARD -->
        <div class="ca-card">

          <!-- CARD HEADER WITH AVATAR -->
          <div class="ca-card-header">
            <div style="display:flex; align-items:center; gap:1rem;">

              <!-- AVATAR CIRCLE -->
              <div style="
                width: 52px;
                height: 52px;
                border-radius: 50%;
                background: rgba(138,144,96,0.15);
                border: 2px solid var(--olive);
                display: flex;
                align-items: center;
                justify-content: center;
                font-family: 'Playfair Display', serif;
                font-weight: 900;
                font-size: 1.3rem;
                color: var(--olive);
                flex-shrink: 0;
              ">
                <%= contact.first_name.charAt(0).toUpperCase() %>
              </div>

              <!-- NAME + LABEL -->
              <div>
                <h2 class="ca-card-title" style="margin-bottom:2px;">
                  <%= contact.first_name %> <%= contact.last_name %>
                </h2>
                <span style="
                  font-family:'DM Sans',sans-serif;
                  font-size:0.72rem;
                  color:var(--text-soft);
                  font-weight:500;
                  text-transform:uppercase;
                  letter-spacing:0.07em;
                ">
                  <i class="fa fa-circle" style="color:var(--olive); font-size:0.5rem; margin-right:4px;"></i>
                  Saved Contact
                </span>
              </div>
            </div>
          </div>

          <!-- DETAILS BODY -->
          <div style="padding: 1.75rem;">

            <!-- DETAIL ROW: First Name -->
            <div style="
              display:flex;
              align-items:center;
              padding: 0.9rem 0;
              border-bottom: 1px solid var(--border);
              gap: 1rem;
              flex-wrap: wrap;
            ">
              <div style="min-width:120px;">
                <span class="ca-form-label" style="margin:0;">
                  <i class="fa fa-user" style="margin-right:5px; color:var(--tan);"></i>
                  First Name
                </span>
              </div>
              <div style="font-family:'DM Sans',sans-serif; font-size:0.95rem; color:var(--text-light); flex:1;">
                <%= contact.first_name %>
              </div>
            </div>

            <!-- DETAIL ROW: Last Name -->
            <div style="
              display:flex;
              align-items:center;
              padding: 0.9rem 0;
              border-bottom: 1px solid var(--border);
              gap: 1rem;
              flex-wrap: wrap;
            ">
              <div style="min-width:120px;">
                <span class="ca-form-label" style="margin:0;">
                  <i class="fa fa-user" style="margin-right:5px; color:var(--tan);"></i>
                  Last Name
                </span>
              </div>
              <div style="font-family:'DM Sans',sans-serif; font-size:0.95rem; color:var(--text-light); flex:1;">
                <%= contact.last_name %>
              </div>
            </div>

            <!-- DETAIL ROW: Email -->
            <div style="
              display:flex;
              align-items:center;
              padding: 0.9rem 0;
              border-bottom: 1px solid var(--border);
              gap: 1rem;
              flex-wrap: wrap;
            ">
              <div style="min-width:120px;">
                <span class="ca-form-label" style="margin:0;">
                  <i class="fa fa-envelope" style="margin-right:5px; color:var(--tan);"></i>
                  Email
                </span>
              </div>
              <div style="font-family:'DM Sans',sans-serif; font-size:0.95rem; color:var(--text-light); flex:1;">
                <%= contact.email %>
              </div>
            </div>

            <!-- DETAIL ROW: Phone -->
            <div style="
              display:flex;
              align-items:center;
              padding: 0.9rem 0;
              border-bottom: 1px solid var(--border);
              gap: 1rem;
              flex-wrap: wrap;
            ">
              <div style="min-width:120px;">
                <span class="ca-form-label" style="margin:0;">
                  <i class="fa fa-phone" style="margin-right:5px; color:var(--tan);"></i>
                  Phone
                </span>
              </div>
              <div style="font-family:'DM Sans',sans-serif; font-size:0.95rem; color:var(--text-light); flex:1;">
                <%= contact.phone %>
              </div>
            </div>

            <!-- DETAIL ROW: Address -->
            <div style="
              display:flex;
              align-items:flex-start;
              padding: 0.9rem 0;
              gap: 1rem;
              flex-wrap: wrap;
            ">
              <div style="min-width:120px;">
                <span class="ca-form-label" style="margin:0;">
                  <i class="fa fa-map-marker" style="margin-right:5px; color:var(--tan);"></i>
                  Address
                </span>
              </div>
              <div style="font-family:'DM Sans',sans-serif; font-size:0.95rem; color:var(--text-light); flex:1; line-height:1.6;">
                <%= contact.address %>
              </div>
            </div>

            <!-- DIVIDER -->
            <div style="height:1px; background:var(--border); margin: 0.5rem 0 1.5rem;"></div>

            <!-- ACTION BUTTONS -->
            <div class="d-flex gap-3 flex-wrap">
              <a href="/update-contact/<%= contact._id %>" class="ca-btn-edit">
                <i class="fa fa-edit"></i> Edit
              </a>
              <a href="/delete-contact/<%= contact._id %>" class="ca-btn-danger">
                <i class="fa fa-trash"></i> Delete
              </a>
              <a href="/" class="ca-btn-cancel">
                <i class="fa fa-arrow-left"></i> Back
              </a>
            </div>

          </div>
        </div>

      </div>
    </div>
  </div>
</main>

<%- include('partials/footer.ejs') %>