<%- include('partials/header.ejs') %>

<main class="ca-page">
  <div class="container">

    <!-- PAGE HEADER -->
    <div class="mb-4" style="animation: fadeUp 0.35s cubic-bezier(0.22,1,0.36,1) both;">
      <div class="ca-badge">✦ Your Contacts</div>
      <h1 style="font-family:'Playfair Display',serif; font-size:clamp(1.8rem,4vw,2.4rem); font-weight:900; color:var(--text-light); letter-spacing:-0.02em; margin:0 0 0.25rem;">
        All Contacts
      </h1>
      <p style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:var(--text-soft); margin:0;">
        Manage, view and organise all your saved contacts
      </p>
    </div>

    <!-- CARD -->
    <div class="ca-card">

      <!-- CARD HEADER -->
      <div class="ca-card-header">
        <h2 class="ca-card-title">
          <i class="fa fa-address-book" style="color:var(--olive); margin-right:0.5rem;"></i>
          Contact List
        </h2>
        <a href="/add-contact" class="ca-btn-primary">
          <i class="fa fa-plus-circle"></i> Add New
        </a>
      </div>

      <!-- TABLE (desktop) -->
      <div class="table-responsive d-none d-md-block">
        <table class="ca-table">
          <thead>
            <tr>
              <th>#</th>
              <th>First Name</th>
              <th>Last Name</th>
              <th>Email</th>
              <th>Phone</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% var srno = counter %>
            <% contacts.forEach(contact => { %>
              <tr>
                <td><%= srno++ %></td>
                <td><%= contact.first_name %></td>
                <td><%= contact.last_name %></td>
                <td><%= contact.email %></td>
                <td><%= contact.phone %></td>
                <td>
                  <div class="ca-actions">
                    <a href="/show-contact/<%= contact._id %>" class="ca-btn-view" title="View">
                      <i class="fa fa-eye"></i>
                    </a>
                    <a href="/update-contact/<%= contact._id %>" class="ca-btn-edit" title="Edit">
                      <i class="fa fa-edit"></i>
                    </a>
                    <a href="/delete-contact/<%= contact._id %>" class="ca-btn-danger" title="Delete">
                      <i class="fa fa-times"></i>
                    </a>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- MOBILE CARDS (mobile only) -->
      <div class="d-md-none" style="padding: 1rem;">
        <% var srno2 = counter %>
        <% contacts.forEach(contact => { %>
          <div style="
            background: var(--bg-table-row);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 1rem 1.1rem;
            margin-bottom: 0.85rem;
            animation: fadeUp 0.4s cubic-bezier(0.22,1,0.36,1) both;
          ">
            <!-- Name + Number -->
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
              <div>
                <div style="font-family:'Playfair Display',serif; font-size:1rem; font-weight:700; color:var(--text-light);">
                  <%= contact.first_name %> <%= contact.last_name %>
                </div>
                <div style="font-size:0.75rem; color:var(--text-soft); margin-top:1px;">
                  #<%= srno2++ %>
                </div>
              </div>
              <div style="
                font-size:0.72rem;
                background: rgba(138,144,96,0.12);
                border: 1px solid rgba(138,144,96,0.25);
                color: var(--olive);
                border-radius: 20px;
                padding: 3px 10px;
                font-weight: 600;
              ">
                Contact
              </div>
            </div>

            <!-- Details -->
            <div style="font-size:0.83rem; color:var(--text-mid); margin-bottom:0.85rem; line-height:1.8;">
              <div><i class="fa fa-envelope" style="color:var(--tan); width:16px;"></i> <%= contact.email %></div>
              <div><i class="fa fa-phone" style="color:var(--tan); width:16px;"></i> <%= contact.phone %></div>
            </div>

            <!-- Divider -->
            <div style="height:1px; background:var(--border); margin-bottom:0.75rem;"></div>

            <!-- Actions -->
            <div class="ca-actions">
              <a href="/show-contact/<%= contact._id %>" class="ca-btn-view">
                <i class="fa fa-eye"></i> View
              </a>
              <a href="/update-contact/<%= contact._id %>" class="ca-btn-edit">
                <i class="fa fa-edit"></i> Edit
              </a>
              <a href="/delete-contact/<%= contact._id %>" class="ca-btn-danger">
                <i class="fa fa-times"></i> Delete
              </a>
            </div>
          </div>
        <% }); %>
      </div>

      <!-- EMPTY STATE -->
      <% if(contacts.length === 0) { %>
        <div class="ca-empty">
          <span class="ca-empty-icon">📋</span>
          <p style="font-size:1rem; color:var(--text-mid); margin-bottom:1rem;">No contacts found</p>
          <a href="/add-contact" class="ca-btn-primary">
            <i class="fa fa-plus-circle"></i> Add Your First Contact
          </a>
        </div>
      <% } %>

      <!-- PAGINATION -->
      <div style="padding: 1rem 1.5rem 1.5rem;">
        <nav>
          <ul class="pagination justify-content-center ca-pagination mb-0">
            <% let disableClass = hasPrevPage ? "" : "disabled" %>
            <li class="page-item <%= disableClass %>">
              <a class="page-link" href="/?page=<%= prevPage %>">
                <i class="fa fa-chevron-left"></i> Prev
              </a>
            </li>

            <% for(let i = 1; i <= totalPages; i++) {
              let activeClass = currentPage == i ? "active" : "" %>
              <li class="page-item <%= activeClass %>">
                <a class="page-link" href="/?page=<%= i %>"><%= i %></a>
              </li>
            <% } %>

            <% let disableClass2 = hasNextPage ? "" : "disabled" %>
            <li class="page-item <%= disableClass2 %>">
              <a class="page-link" href="/?page=<%= nextPage %>">
                Next <i class="fa fa-chevron-right"></i>
              </a>
            </li>
          </ul>
        </nav>
      </div>

    </div>
  </div>
</main>

<%- include('partials/footer.ejs') %>